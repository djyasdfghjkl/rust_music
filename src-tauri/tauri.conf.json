{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "music-tauri",
  "version": "1.0.0",
  "identifier": "com.lin.music-tauri",
  "build": {
    "beforeDevCommand": "cd ui && trunk serve",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd ui && trunk build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Miku Tunes",
        "width": 1120,
        "height": 720,
        "minWidth": 700,
        "minHeight": 600,
        "center": true,
        "visible": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPCACHE/audio-cache/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
